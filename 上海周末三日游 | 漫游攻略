<script>
  const TOTAL = 13;
  const checked = new Set();
  const emojis = ['🗺️','👟','👟','🏃','🏃','🎯','🎯','🎯','🌟','🌟','🌟','🎊','🎊','🎉'];

  function updateProgress() {
    const n = checked.size;
    document.getElementById('checkedCount').textContent = n;
    document.getElementById('progressFill').style.width = Math.round(n / TOTAL * 100) + '%';
    document.getElementById('progressEmoji').textContent = emojis[n] || '🎉';
    const label = document.getElementById('progressLabel');
    if (n === TOTAL) {
      label.classList.add('done');
      document.getElementById('completionBanner').classList.add('visible');
    } else {
      label.classList.remove('done');
      document.getElementById('completionBanner').classList.remove('visible');
    }
  }

  function toggleItem(id) {
    const item = document.querySelector(`.timeline-item[data-id="${id}"]`);
    if (checked.has(id)) {
      checked.delete(id);
      item.classList.remove('checked');
    } else {
      checked.add(id);
      item.classList.add('checked');
    }
    updateProgress();
  }

  document.querySelectorAll('.timeline-item').forEach(item => {
    const id = parseInt(item.dataset.id);
    item.querySelector('.card-header').addEventListener('click', e => {
      if (e.target.closest('.check-btn')) return;
      toggleItem(id);
    });
    item.querySelector('.check-btn').addEventListener('click', e => {
      e.stopPropagation();
      toggleItem(id);
    });
  });

  updateProgress();
</script>
